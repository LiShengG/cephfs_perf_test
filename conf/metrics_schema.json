{
  "metrics": [
    {
      "key": "cpu_percent",
      "label": "CPU 使用率",
      "source": "proc_stat",
      "unit": "%"
    },
    {
      "key": "memory_mb",
      "label": "内存使用",
      "source": "proc_stat",
      "unit": "MB"
    },
    {
      "key": "io_read_bytes",
      "label": "IO 读取字节",
      "source": "proc_stat",
      "unit": "bytes"
    },
    {
      "key": "io_write_bytes",
      "label": "IO 写入字节",
      "source": "proc_stat",
      "unit": "bytes"
    },
    {
      "key": "open_files",
      "label": "打开文件数",
      "source": "proc_stat",
      "unit": "count"
    },
    {
      "key": "server.handle_client_request",
      "label": "MDS 请求处理",
      "source": "perf_dump",
      "unit": "count"
    },
    {
      "key": "server.journal_latency",
      "label": "日志延迟",
      "source": "perf_dump",
      "unit": "sec"
    },
    {
      "key": "mds_cache.num_inodes",
      "label": "Inode 数量",
      "source": "perf_dump",
      "unit": "count"
    },
    {
      "key": "mds_cache.num_caps",
      "label": "Caps 数量",
      "source": "perf_dump",
      "unit": "count"
    }
  ]
}
